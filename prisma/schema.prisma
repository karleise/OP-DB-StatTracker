generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchupKind {
  GOOD
  BAD
}

enum Result {
  WIN
  LOSS
}

enum TurnOrder {
  FIRST
  SECOND
}

enum Game {
  OP
  DB
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  password        String
  role            Role     @default(USER)
  createdAt       DateTime @default(now())

  matchesAsPlayer Match[]  @relation("PlayerMatches")
  matchesAsRival  Match[]  @relation("RivalMatches")
}

model Leader {
  id        String  @id
  name      String
  life      Int?
  power     Int?
  attribute String?
  tribe     String?
  imageUrl  String  @db.Text
  game      Game    @default(OP)

  colors          LeaderColor[]
  guide           Guide?
  matchupAppearances GuideMatchup[]
  playerMatches   Match[] @relation("PlayerLeader")
  rivalMatches    Match[] @relation("RivalLeader")

  @@index([game])
}

model Color {
  id      Int           @id @default(autoincrement())
  name    String        @unique
  hex     String?

  leaders LeaderColor[]
  guides  GuideColor[]
}

model LeaderColor {
  leaderId String
  colorId  Int

  leader Leader @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  color  Color  @relation(fields: [colorId],  references: [id], onDelete: Cascade)

  @@id([leaderId, colorId])
  @@index([colorId])
}

model Difficulty {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  order  Int     @default(0)
  guides Guide[]
}

model PlayStyle {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  guides GuidePlayStyle[]
}

model Guide {
  id           String   @id @default(cuid())
  leaderId     String   @unique
  body         String   @db.Text
  difficultyId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leader     Leader            @relation(fields: [leaderId],     references: [id])
  difficulty Difficulty        @relation(fields: [difficultyId], references: [id])
  colors     GuideColor[]
  playStyles GuidePlayStyle[]
  matchups   GuideMatchup[]

  @@index([difficultyId])
}

model GuidePlayStyle {
  guideId     String
  playStyleId Int

  guide     Guide     @relation(fields: [guideId],     references: [id], onDelete: Cascade)
  playStyle PlayStyle @relation(fields: [playStyleId], references: [id], onDelete: Cascade)

  @@id([guideId, playStyleId])
  @@index([playStyleId])
}

model GuideColor {
  guideId String
  colorId Int

  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  color Color @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([guideId, colorId])
  @@index([colorId])
}

model GuideMatchup {
  id       String      @id @default(cuid())
  guideId  String
  leaderId String
  kind     MatchupKind

  guide  Guide  @relation(fields: [guideId],  references: [id], onDelete: Cascade)
  leader Leader @relation(fields: [leaderId], references: [id])

  @@unique([guideId, leaderId, kind])
  @@index([leaderId])
}

model Match {
  id             String   @id @default(cuid())
  playerId       String
  playerLeaderId String
  rivalId        String?
  rivalName      String?
  rivalLeaderId  String
  result         Result
  turnOrder      TurnOrder?
  notes          String?  @db.Text
  playedAt       DateTime @default(now())

  player       User    @relation("PlayerMatches", fields: [playerId],       references: [id], onDelete: Cascade)
  playerLeader Leader  @relation("PlayerLeader",  fields: [playerLeaderId], references: [id])
  rival        User?   @relation("RivalMatches",  fields: [rivalId],        references: [id], onDelete: SetNull)
  rivalLeader  Leader  @relation("RivalLeader",   fields: [rivalLeaderId],  references: [id])

  @@index([playerId])
  @@index([rivalId])
  @@index([playerLeaderId])
  @@index([rivalLeaderId])
  @@index([playedAt])
}
